{
  "name": "appscripts",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx concurrently -n sso,doc,work -c blue,green,yellow \"npm run dev:sso\" \"npm run dev:docmgr\" \"npm run dev:workmgr\"",
    "dev:docmgr": "npm run dev -w apps/docmgr",
    "dev:sso": "npm run dev -w apps/sso-portal",
    "dev:license": "npm run dev -w apps/license-server",
    "test": "npm run test:docmgr",
    "test:docmgr": "npm run test -w apps/docmgr",
    "build:docmgr": "npm run build -w apps/docmgr",
    "build:sso": "npm run build -w apps/sso-portal",
    "build:license": "npm run build -w apps/license-server",
    "deploy:sso": "node scripts/deploy.js --app sso-portal",
    "deploy:docmgr": "node scripts/deploy.js --app docmgr",
    "deploy:license": "node scripts/deploy.js --app license-server",
    "dev:workmgr": "npm run dev -w apps/workmgr",
    "build:workmgr": "npm run build -w apps/workmgr",
    "deploy:workmgr": "node scripts/deploy.js --app workmgr"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "concurrently": "^9.2.1",
    "javascript-obfuscator": "^4.1.1",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "playwright": "^1.59.1"
  }
}
