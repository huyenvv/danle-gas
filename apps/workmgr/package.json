{
  "name": "@appscripts/workmgr",
  "version": "1.0.0",
  "private": true,
  "gasBundle": {
    "selfContained": true
  },
  "scripts": {
    "dev": "vite --config vite.config.js",
    "dev:server": "tsx dev-server/server.ts",
    "build:client": "vite build --config vite.config.js",
    "build": "npm run typecheck && npm run build:client && npm run build:gas && npm run build:obfuscate && node build/assemble-gas.mjs",
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit",
    "build:gas": "node build/bundle-gas.mjs",
    "build:obfuscate": "node ../../scripts/obfuscate.js --app workmgr",
    "deploy": "clasp push --force && clasp deploy"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/better-sqlite3": "^7.6.13",
    "@types/google-apps-script": "^2.0.11",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^11.10.0",
    "esbuild": "^0.25.12",
    "jest": "^29.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.0.2"
  }
}
