  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "vite": "^6.4.3",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
